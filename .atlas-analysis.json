  "keyFeatures": [
    "Multi-provider usage tracking in menu bar",
    "Session and weekly limit monitoring with reset countdowns",
    "Local cost usage analysis for last 30 days",
    "Merge Icons mode with provider switcher",
    "Bundled CLI for scripts and CI",
    "WidgetKit integration",
    "Privacy-first on-device parsing",
    "Support for 15+ AI coding providers"
  ],
  "publicApiSurface": [
    "codexbar usage - Fetch current usage statistics",
    "codexbar cost - Analyze local token cost usage",
    "codexbar config validate - Validate configuration file",
    "codexbar config dump - Display normalized config",
    "UsageFetcher - Core usage fetching interface",
    "ProviderProtocol - Provider implementation protocol",
    "UsageStore - Central usage state management",
    "StatusItemController - Menu bar status item management",
    "IconRenderer - Dynamic menu bar icon generation",
    "CostUsageFetcher - Local cost analysis scanner"
